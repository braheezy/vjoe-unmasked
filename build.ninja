# Generated by tools/scripts/configure_build.py
ninja_required_version = 1.7

rule configure
  command = python3 tools/scripts/configure_build.py
  description = CONFIGURE build.ninja
  generator = 1

rule uv_sync
  command = UV_CACHE_DIR=.uv-cache uv sync --frozen && mkdir -p build/stamps && touch $out
  description = UV sync
  restat = 1

rule bootstrap_toolchain
  command = ROOT_DIR=. ROM_DIR=rom/SLES_528.68 SOURCE_EXECUTABLE=rom/SLES_528.68/SLES_528.68 WIBO_PATH=tools/wibo-macos WIBO_URL=https://github.com/decompals/wibo/releases/download/1.0.1/wibo-macos EE_GCC_PATH=tools/ee-gcc2.95.3-136/bin/ee-gcc.exe EE_GCC_URL=https://github.com/decompme/compilers/releases/download/compilers/ee-gcc2.95.3-136.tar.gz AS_PATH=tools/binutils-mips-ps2-decompals/mips-ps2-decompals-as OBJCOPY_PATH=tools/binutils-mips-ps2-decompals/mips-ps2-decompals-objcopy BINUTILS_URL=https://github.com/dreamingmoths/binutils-mips-ps2-decompals/releases/download/v0.8-aarch64/binutils-mips-ps2-decompals-macos-arm64.tar.gz OBJDIFF_PATH=tools/objdiff-cli-macos-arm64 OBJDIFF_URL=https://github.com/encounter/objdiff/releases/download/v3.6.0/objdiff-cli-macos-arm64 bash tools/scripts/bootstrap_toolchain.sh $out
  description = SETUP toolchain
  restat = 1

rule split_outputs
  command = python3 tools/scripts/configure_build.py split && mkdir -p build/stamps && touch $out
  description = SPLIT assets
  restat = 1

rule compile_c
  command = PATH=tools/ee-gcc2.95.3-136/bin:$PATH tools/wibo-macos tools/ee-gcc2.95.3-136/bin/ee-gcc.exe -O2 -G0 -Iviewtiful-joe-2/src -Iviewtiful-joe-2/include -Wa,-Iviewtiful-joe-2/include -Wa,-Iviewtiful-joe-2/config/SLES_528.68 -c $in -o $out
  description = CC $out

rule compile_c_expected
  command = PATH=tools/ee-gcc2.95.3-136/bin:$PATH tools/wibo-macos tools/ee-gcc2.95.3-136/bin/ee-gcc.exe -O2 -G0 -Iviewtiful-joe-2/src -Iviewtiful-joe-2/include -Wa,-Iviewtiful-joe-2/include -Wa,-Iviewtiful-joe-2/config/SLES_528.68 -c $in -o $out
  description = CC(expected) $out

rule compile_asm
  command = tools/binutils-mips-ps2-decompals/mips-ps2-decompals-as -EL -march=r5900 -mabi=eabi -G=0 -mno-pdr -Iviewtiful-joe-2/include -Iviewtiful-joe-2/config/SLES_528.68 -o $out $in
  description = AS $out

rule compile_asm_expected
  command = tools/binutils-mips-ps2-decompals/mips-ps2-decompals-as -EL -march=r5900 -mabi=eabi -G=0 -mno-pdr -Iviewtiful-joe-2/include -Iviewtiful-joe-2/config/SLES_528.68 -o $out $in
  description = AS(expected) $out

rule partial_link
  command = tools/binutils-mips-ps2-decompals/mips-ps2-decompals-ld -r -EL -o $out $in
  description = LD -r $out

rule link
  command = tools/binutils-mips-ps2-decompals/mips-ps2-decompals-ld -EL -T viewtiful-joe-2/config/SLES_528.68/linkers/SLES_528.68.ld -e entry -Map $out.map -o $out @$out.rsp
  description = LINK $out
  rspfile = $out.rsp
  rspfile_content = $in

rule merge_objdiff
  command = .venv/bin/python tools/scripts/configure_build.py merge-objdiff --categories-path viewtiful-joe-2/config/SLES_528.68/categories.json --output-path $out $in
  description = MERGE $out

rule generate_objdiff
