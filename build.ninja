  description = OBJDIFF $out

rule report
  command = tools/objdiff-cli-macos-arm64 report generate -o $out build/SLES_528.68/objdiff.json
  description = REPORT $out

rule diff
  command = tools/scripts/diff.sh SLES_528.68 viewtiful-joe-2/config/SLES_528.68 build/SLES_528.68 tools/binutils-mips-ps2-decompals/mips-ps2-decompals-objcopy && mkdir -p build/stamps && touch $out
  description = DIFF

rule clean_tree
  command = rm -rf build/SLES_528.68 asm viewtiful-joe-2/config/SLES_528.68/assets viewtiful-joe-2/config/SLES_528.68/linkers && mkdir -p build/stamps && touch $out
